{
  "name": "Modern Executive Light",
  "dataColors": [
    "#2563EB",
    "#14B8A6",
    "#059669",
    "#F59E0B",
    "#EC4899",
    "#7C3AED",
    "#DC2626",
    "#64748B",
    "#0EA5E9",
    "#84CC16"
  ],
  "background": "#EEF3F8",
  "foreground": "#0F172A",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "transparency": 0
          }
        ],
        "visualBorder": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "radius": 10
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 90,
            "blur": 5
          }
        ]
      }
    }
  },
  "backgroundLight": "#FFFFFF",
  "foregroundNeutralSecondary": "#475569",
  "foregroundNeutralTertiary": "#94A3B8",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#0F172A"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#0F172A"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#334155"
    },
    "label": {
      "fontSize": 9,
      "fontFace": "Segoe UI",
      "color": "#475569"
    }
  }
}